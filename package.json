{
  "displayName": "Homebridge Dwelo Plugin",
  "name": "@eduardoramirez/homebridge-dwelo",
  "version": "1.5.0",
  "description": "Adds support for Dwelo accessories to Homebridge.",
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/eduardoramirez/homebridge-dwelo.git"
  },
  "bugs": {
    "url": "https://github.com/eduardoramirez/homebridge-dwelo/issues"
  },
  "engines": {
    "node": "^22.13.0 || ^24.0.0",
    "homebridge": "^2.1.0"
  },
  "main": "dist/index.js",
  "scripts": {
    "lint": "eslint src --max-warnings=0",
    "test": "npm run build && node --test test/*.test.mjs",
    "watch": "npm run build && npm link && nodemon",
    "build": "rimraf ./dist && tsc",
    "prepublishOnly": "npm run lint && npm run build"
  },
  "keywords": [
    "homebridge-plugin"
  ],
  "dependencies": {
    "axios": "1.18.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "24.13.2",
    "eslint": "10.6.0",
    "homebridge": "2.1.0",
    "nodemon": "3.1.14",
    "rimraf": "6.1.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1"
  }
}
