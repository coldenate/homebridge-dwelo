{
  "pluginAlias": "HomebridgePluginDwelo",
  "pluginType": "platform",
  "singular": true,
  "schema": {
    "type": "object",
    "properties": {
      "token": {
        "title": "Token",
        "type": "string",
        "format": "password",
        "required": true
      },
      "gatewayId": {
        "title": "Gateway ID",
        "type": "string",
        "required": true
      },
      "lockPollMs": {
        "title": "How often to poll for the lock status (milliseconds)",
        "type": "number",
        "default": 60000,
        "minimum": 1000
      },
      "autoLockMinutes": {
        "title": "Auto lock delay (minutes)",
        "type": "number",
        "default": 3,
        "minimum": 0
      },
      "thermostatDisplayUnits": {
        "title": "Thermostat display units",
        "type": "string",
        "default": "celsius",
        "oneOf": [
          {
            "title": "Celsius",
            "enum": [
              "celsius"
            ]
          },
          {
            "title": "Fahrenheit",
            "enum": [
              "fahrenheit"
            ]
          }
        ]
      },
      "exposeThermostatHumidity": {
        "title": "Expose thermostat humidity",
        "type": "boolean",
        "default": true
      },
      "exposeThermostatBattery": {
        "title": "Expose thermostat battery",
        "type": "boolean",
        "default": true
      },
      "logThermostatSensorInventory": {
        "title": "Log thermostat sensor inventory",
        "description": "Debug option that logs thermostat sensor names and sanitized values without logging tokens or raw API responses.",
        "type": "boolean",
        "default": false
      }
    }
  }
}
